# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ai_resume_matcher

# JWT signing secret (use a long random string in production)
JWT_SECRET=your-jwt-secret-here

# Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key-here

# Comma-separated Gemini models to try in order (create key at https://aistudio.google.com/apikey)
# Avoid gemini-2.0-flash on free tier — it often has zero quota.
GEMINI_MODEL=gemini-2.5-flash

# Allowed frontend origin(s), comma-separated. Leave empty for unrestricted local development.
CLIENT_URL=http://localhost:5173

# Persistent PDF directory (optional; defaults to server/uploads)
UPLOADS_DIR=./uploads

# Set to false on ephemeral hosts; extracted resume text remains saved in PostgreSQL
PERSIST_UPLOADS=true

# Server port (optional, defaults to 5001 — 5000 is often used by macOS AirPlay)
PORT=5001
