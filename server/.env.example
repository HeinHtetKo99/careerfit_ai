# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ai_resume_matcher

# JWT signing secret (use a long random string in production)
JWT_SECRET=your-jwt-secret-here

# Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key-here

# Comma-separated Gemini models to try in order (create key at https://aistudio.google.com/apikey)
GEMINI_MODEL=gemini-2.5-flash,gemini-2.0-flash

# Set to true only if you want basic keyword matching when Gemini is unavailable
GEMINI_FALLBACK=false

# Server port (optional, defaults to 5001 — 5000 is often used by macOS AirPlay)
PORT=5001
